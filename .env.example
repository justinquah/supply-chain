# Database
# For local dev: use SQLite file
# For production (Vercel): use Turso (libsql) URLs below
DATABASE_URL="file:./dev.db"

# Turso (production only - leave blank for local dev)
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-long-random-string-in-production"
NEXTAUTH_URL="http://localhost:3001"
# For production: NEXTAUTH_URL="https://your-app.vercel.app"

# TikTok Shop API (get from https://partner.tiktokshop.com)
TIKTOK_SHOP_APP_KEY=""
TIKTOK_SHOP_APP_SECRET=""
# TIKTOK_SHOP_ACCESS_TOKEN=""  # Auto-set after OAuth

# Lazada API (get from https://open.lazada.com)
# LAZADA_APP_KEY=""
# LAZADA_APP_SECRET=""
# LAZADA_COUNTRY="MY"
# LAZADA_ACCESS_TOKEN=""  # Auto-set after OAuth

# Shopee Open API (get from https://open.shopee.com)
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_ENVIRONMENT="sandbox"  # or "live"
# SHOPEE_ACCESS_TOKEN=""  # Auto-set after OAuth
# SHOPEE_SHOP_ID=""  # Auto-set after OAuth
