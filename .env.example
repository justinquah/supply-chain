# Supabase — required for all environments
# Get these values from: Supabase Dashboard -> Project Settings -> API

# The project URL (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# The anonymous (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# The service-role secret key — SERVER ONLY, never prefix with NEXT_PUBLIC_.
# Used by the admin client for user invite and role management (bypasses RLS).
# Set in Vercel: Project -> Settings -> Environment Variables (Production)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
